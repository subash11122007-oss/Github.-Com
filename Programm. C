#include <stdio.h>

struct Student {
    int id;
    char name[50];
    float marks;
};

int main() {
    int n, i;
    
    printf("Enter number of students: ");
    scanf("%d", &n);

    struct Student s[n];

    // Input details
    for(i = 0; i < n; i++) {
        printf("\nEnter details for Student %d\n", i + 1);
        
        printf("ID: ");
        scanf("%d", &s[i].id);
        
        printf("Name: ");
        scanf("%s", s[i].name);
        
        printf("Marks: ");
        scanf("%f", &s[i].marks);
    }

    // Display details
    printf("\n--- Student Details ---\n");
    for(i = 0; i < n; i++) {
        printf("\nStudent %d\n", i + 1);
        printf("ID: %d\n", s[i].id);
        printf("Name: %s\n", s[i].name);
        printf("Marks: %.2f\n", s[i].marks);
    }

    // Find highest marks
    float max = s[0].marks;
    int topIndex = 0;

    for(i = 1; i < n; i++) {
        if(s[i].marks > max) {
            max = s[i].marks;
            topIndex = i;
        }
    }

    printf("\nTop Student:\n");
    printf("Name: %s\n", s[topIndex].name);
    printf("Marks: %.2f\n", s[topIndex].marks);

    // Average marks
    float sum = 0;
    for(i = 0; i < n; i++) {
        sum += s[i].marks;
    }

    printf("\nAverage Marks: %.2f\n", sum / n);

    return 0;
}
